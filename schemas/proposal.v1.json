{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/stroupaloop/openclaw-resolver/main/schemas/proposal.v1.json",
  "title": "OpenClaw Resolver Tuning Proposal",
  "description": "Machine-readable proposal for a description change, generated by a tuning cron and consumed by a review surface (e.g., Mission Control). Proposals are evidence-backed, validated against failure sets, and never applied automatically.",
  "type": "object",
  "required": ["schemaVersion", "id", "generatedAt", "source", "summary", "proposals"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "integer", "const": 1 },
    "id": {
      "type": "string",
      "description": "Stable identifier for the proposal run (e.g., 'proposal-2026-04-20-daily-tuning')."
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "required": ["kind", "host", "agentId"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["daily-tuning-cron", "monthly-benchmark-cron", "manual", "other"]
        },
        "host": { "type": "string", "description": "Host identifier where the proposal was generated." },
        "agentId": { "type": "string" },
        "runbookVersion": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "description": "Aggregate telemetry metrics for the analysis window.",
      "properties": {
        "windowHours": { "type": "integer" },
        "totalClassifications": { "type": "integer" },
        "lowConfidenceCount": { "type": "integer" },
        "cacheDisagreementCount": { "type": "integer" },
        "topMissedTools": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "topMissedSkills": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "anomalyFlags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Labels like 'drift', 'low-confidence-spike', 'error-spike'. Triggers MC alerts."
        }
      }
    },
    "proposals": {
      "type": "array",
      "description": "Individual description-edit proposals. MAY be empty if no confident recommendations emerged.",
      "items": {
        "type": "object",
        "required": ["id", "scope", "targetId", "operation", "currentValue", "proposedValue", "rationale", "validation", "patch", "decision"],
        "properties": {
          "id": { "type": "string" },
          "scope": {
            "type": "string",
            "enum": ["tool", "skill"]
          },
          "targetId": {
            "type": "string",
            "description": "Tool or skill ID being modified (e.g., 'nodes', 'github')."
          },
          "operation": {
            "type": "string",
            "enum": ["replace", "remove"],
            "description": "'replace' swaps the description; 'remove' drops an override (reverts to default)."
          },
          "currentValue": {
            "type": ["string", "null"],
            "description": "The description as currently loaded (defaults merged with any active override). null if currently unset."
          },
          "proposedValue": {
            "type": ["string", "null"],
            "description": "The proposed replacement. null if operation is 'remove'."
          },
          "rationale": {
            "type": "string",
            "description": "1-3 sentence explanation for human review."
          },
          "evidence": {
            "type": "object",
            "description": "Prompts and telemetry excerpts supporting the proposal.",
            "properties": {
              "prompts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "excerpt": { "type": "string" },
                    "confidence": { "type": "number" },
                    "timestamp": { "type": "string", "format": "date-time" },
                    "sessionId": { "type": "string" }
                  }
                }
              },
              "promptsTotal": { "type": "integer" }
            }
          },
          "validation": {
            "type": "object",
            "description": "Benchmark validation results. proposedRecall MUST be >= baselineRecall on the failure set, AND proposedRecall on canonical sample MUST NOT regress, for passesValidationGate to be true.",
            "required": ["passesValidationGate"],
            "properties": {
              "failureSet": {
                "type": "object",
                "properties": {
                  "baselineRecall": { "type": "number" },
                  "proposedRecall": { "type": "number" },
                  "n": { "type": "integer" }
                }
              },
              "canonicalSample": {
                "type": "object",
                "properties": {
                  "baselineRecall": { "type": "number" },
                  "proposedRecall": { "type": "number" },
                  "n": { "type": "integer" }
                }
              },
              "passesValidationGate": { "type": "boolean" },
              "notes": { "type": "string" }
            }
          },
          "patch": {
            "type": "object",
            "description": "Apply-ready instructions for the override file. Consumers SHOULD treat this as the canonical write target.",
            "required": ["file", "jsonPath", "operation"],
            "properties": {
              "file": {
                "type": "string",
                "description": "Filename hint ('resolver-catalog.json'). The actual path is determined by the resolver's catalogOverridesFile config."
              },
              "jsonPath": {
                "type": "string",
                "description": "JSONPath expression targeting the field in the override catalog (e.g., '$.tools.nodes', '$.skills.github')."
              },
              "operation": {
                "type": "string",
                "enum": ["replace", "add", "remove"]
              },
              "value": {
                "type": ["string", "null"]
              }
            }
          },
          "decision": {
            "type": "object",
            "description": "Review decision state. Populated by the reviewer (MC or human).",
            "required": ["status"],
            "properties": {
              "status": {
                "type": "string",
                "enum": ["pending_review", "approved", "rejected", "snoozed", "applied"]
              },
              "decidedAt": { "type": ["string", "null"], "format": "date-time" },
              "decidedBy": { "type": ["string", "null"] },
              "decisionReason": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Free-form notes about the run (e.g., 'N hypotheses evaluated but failed validation gate')."
    }
  },
  "additionalProperties": false
}
